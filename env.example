# Copy this file to ".env" and fill in real values:  cp env.example .env
#
# ---------------------------------------------------------------------------
# Database (Supabase Postgres)
# Use the "Connection pooling" string for DATABASE_URL and the direct string
# for DIRECT_URL (used by migrations).
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# Generate AUTH_SECRET with: npx auth secret  (or: openssl rand -base64 32)
# ---------------------------------------------------------------------------
AUTH_SECRET="replace-with-a-long-random-string"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Email (Resend) - used to send magic-link sign-in emails
# ---------------------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Your Brand <login@yourdomain.com>"

# ---------------------------------------------------------------------------
# Supabase Storage (private bucket for the eBook PDF + cover)
# ---------------------------------------------------------------------------
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="service-role-key-server-only"
SUPABASE_STORAGE_BUCKET="ebook"

# ---------------------------------------------------------------------------
# Ziina payments
# Get a token at https://docs.ziina.com/developers/custom-integration
# ---------------------------------------------------------------------------
ZIINA_API_TOKEN="ziina-bearer-token"
ZIINA_WEBHOOK_SECRET="your-own-shared-secret-for-hmac"
ZIINA_TEST_MODE="true"

# ---------------------------------------------------------------------------
# Admin bootstrap - this email is seeded/promoted to ADMIN
# ---------------------------------------------------------------------------
ADMIN_EMAIL="admin@yourdomain.com"
